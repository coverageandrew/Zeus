# Zeus LLM Provider Configuration
# ================================
# Choose your preferred LLM provider and set the appropriate API key.
# Only one provider needs to be configured.

# Provider Selection (openai | anthropic | google)
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
# Optional: Override default models
# LLM_MODEL_COMPANY_HEAD=gpt-4.1
# LLM_MODEL_DEPT_HEAD=gpt-4.1-mini
# LLM_MODEL_SUB_AGENT=gpt-4.1-mini
# LLM_MODEL_SUMMARIZER=gpt-4.1-nano

# Anthropic Configuration (if using Claude)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# LLM_MODEL_COMPANY_HEAD=claude-sonnet-4-20250514
# LLM_MODEL_DEPT_HEAD=claude-sonnet-4-20250514
# LLM_MODEL_SUB_AGENT=claude-sonnet-4-20250514

# Google Configuration (if using Gemini)
# GOOGLE_API_KEY=AIza-your-google-api-key-here
# LLM_MODEL_COMPANY_HEAD=gemini-2.0-flash
# LLM_MODEL_DEPT_HEAD=gemini-2.0-flash
# LLM_MODEL_SUB_AGENT=gemini-2.0-flash

# Optional: Custom base URL (for proxies or self-hosted models)
# LLM_BASE_URL=https://api.openai.com/v1

# Server Configuration
PORT=8000
